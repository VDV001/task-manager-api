:80 {
	handle /api/* {
		reverse_proxy api:8080
	}

	handle /swagger/* {
		reverse_proxy api:8080
	}

	handle /healthz {
		reverse_proxy api:8080
	}

	handle /readyz {
		reverse_proxy api:8080
	}

	handle /version {
		reverse_proxy api:8080
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
