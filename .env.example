# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_SHUTDOWN_TIMEOUT=5s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=taskmanager
DB_PASSWORD=taskmanager
DB_NAME=taskmanager
DB_SSL_MODE=disable

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=info
